# AyurSutra Server - Environment Variables

# Server Port
PORT=3001

# Groq API for LLM Features
GROQ_API_KEY=gsk_your_api_key_here

# SendGrid Direct Mail Integration (Optional but recommended)
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Gmail SMTP Fallback (If SendGrid not used)
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_app_password

# ML Service running locally
ML_SERVICE_URL=http://localhost:8000

# Firebase Admin SDK Configuration
# Recommended: Ensure GOOGLE_APPLICATION_CREDENTIALS points to your service account JSON file, 
# OR provide standard variables below if preferred
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com
# Use real newline characters for the private key
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nPrivate\nKey\n-----END PRIVATE KEY-----\n"

# Google Calendar (OAuth2 Web application — same GCP project as Firebase is OK)
# Create: APIs & Services → Credentials → OAuth 2.0 Client ID → Web application
# Enable "Google Calendar API" for the project.
# Authorized redirect URI (must match exactly): e.g. http://localhost:3001/api/calendar/oauth/callback
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/calendar/oauth/callback
# Where users return after linking (Vite app)
PUBLIC_APP_URL=http://localhost:5173
