# AyurSutra Server - Environment Variables

# Server Port
PORT=3001

# Groq API for LLM Features
GROQ_API_KEY=gsk_your_api_key_here

# SendGrid Direct Mail Integration (Optional but recommended)
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Gmail SMTP Fallback (If SendGrid not used)
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_app_password

# ML Service running locally
ML_SERVICE_URL=http://localhost:8000

# Firebase Admin SDK Configuration
# Recommended: Ensure GOOGLE_APPLICATION_CREDENTIALS points to your service account JSON file, 
# OR provide standard variables below if preferred
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com
# Use real newline characters for the private key
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nPrivate\nKey\n-----END PRIVATE KEY-----\n"
